#!/usr/bin/env bash
set -euo pipefail

# Installs the runtimes pinned in the managed mise config (~/.config/mise).
# run_onchange_ + after_: re-runs whenever this rendered script changes, and
# the hash below changes with the config — so bumping a runtime version in the
# repo installs it on every machine at its next apply/update. Runs AFTER files
# are applied so the new config is already in place.
# mise config hash: {{ include "dot_config/mise/config.toml" | sha256sum }}

eval "$(/opt/homebrew/bin/brew shellenv)"
mise install
