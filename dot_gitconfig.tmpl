[user]
    name = Jóni Oliveira
    email = joni@jonioliveira.dev
    signingkey = ~/.ssh/id_ed25519.pub

[init]
    defaultBranch = main

[pull]
    ff = only

[core]
    pager = delta

[interactive]
    diffFilter = delta --color-only

[delta]
    navigate = true

[push]
    autoSetupRemote = true

[gpg]
    format = ssh

[commit]
    gpgsign = true
{{ if .isWork }}
[includeIf "gitdir:~/workspace/"]
    path = ~/.gitconfig-work
{{- end }}
