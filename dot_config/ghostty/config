# Managed by chezmoi. Ghostty terminal configuration.
# Ghostty ships sensible defaults; only overrides are set here.
# Docs: https://ghostty.org/docs/config  •  Reload: Cmd+Shift+,

# Theme — built-in. Browse others with `ghostty +list-themes`.
theme = Catppuccin Mocha

# Font — JetBrains Mono (installed). Falls back to system mono if absent.
font-family = JetBrains Mono
font-size = 14

# --- Window Style ---
window-decoration = true
background-opacity = 0.85
background-blur-radius = 20
window-padding-x = 12
window-padding-y = 12

# --- Cursor ---
cursor-style = bar
cursor-style-blink = true
cursor-color = #d4ff00

# --- Keybindings ---
keybind = super+t=new_tab
keybind = super+n=new_window
keybind = super+d=new_split:right
keybind = super+shift+d=new_split:down

# --- Interaction ---
copy-on-select = clipboard
confirm-close-surface = false
mouse-hide-while-typing = true

# --- Secret Sauce ---
# Ensures your SSH sessions carry your terminfo
shell-integration = zsh

