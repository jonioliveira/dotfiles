#!/usr/bin/env bash
set -euo pipefail

# run_onchange_: re-runs whenever this rendered script's content changes. The
# hash below changes with Brewfile.tmpl, so adding a package to the Brewfile
# re-runs `brew bundle` on every machine at its next apply/update.
# Brewfile hash: {{ include "Brewfile.tmpl" | sha256sum }}

# Don't let `brew bundle` auto-update Homebrew or upgrade existing packages —
# this script gates `chezmoi apply`, so it must be fast and idempotent. It
# INSTALLS anything missing and leaves already-installed packages untouched.
# (Upgrades are a separate, deliberate `brew upgrade`, never a side effect of
# applying dotfiles.)
export HOMEBREW_NO_AUTO_UPDATE=1
export HOMEBREW_NO_ENV_HINTS=1

# Install Homebrew if missing
if ! command -v brew >/dev/null 2>&1; then
  /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
fi
eval "$(/opt/homebrew/bin/brew shellenv)"

# Install 1Password CLI early — secret-bearing templates need it
if ! command -v op >/dev/null 2>&1; then
  brew install --cask 1password-cli
fi

# Render the Brewfile from the template and install everything it declares.
# This script is itself rendered by chezmoi, so {{ .isWork }} below is
# already the real value for THIS machine. We pass it to execute-template via
# --override-data (the only flag that sets a data key; --promptBool does NOT,
# because Brewfile.tmpl reads .isWork as data, not a promptBool call).
# --no-upgrade: install missing packages only; never upgrade installed ones.
RENDERED_BREWFILE="$(mktemp)"
trap 'rm -f "$RENDERED_BREWFILE"' EXIT
chezmoi execute-template --override-data '{"isWork":{{ .isWork }}}' \
  < "{{ .chezmoi.sourceDir }}/Brewfile.tmpl" > "$RENDERED_BREWFILE"
brew bundle --no-upgrade --file="$RENDERED_BREWFILE"
